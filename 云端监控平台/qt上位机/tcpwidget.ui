    color: #1e293b;
    background-color: #f8fafc;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    padding: 0 12px;
}

QLineEdit:focus {
    background-color: #ffffff;
    border: 2px solid #3b82f6;
}

QTextEdit {
    color: #334155;
    background-color: #fbfdff;
    border: 1px solid #cbd5e1;
    border-radius: 10px;
    padding: 8px;
}

QPushButton#pushButton_connect {
    min-width: 132px;
    min-height: 40px;
    color: white;
    background-color: #2563eb;
    border: none;
    border-radius: 9px;
    padding: 0 18px;
    font-size: 13px;
    font-weight: 600;
}

QPushButton#pushButton_connect:hover {
    background-color: #3b82f6;
}

QPushButton#pushButton_connect:pressed {
    background-color: #1d4ed8;
}

QPushButton#pushButton_2_send {
    min-width: 104px;
    min-height: 40px;
    color: white;
    background-color: #0f766e;
    border: none;
    border-radius: 9px;
    padding: 0 16px;
    font-size: 13px;
    font-weight: 600;
}

QPushButton#pushButton_2_send:hover {
    background-color: #0d9488;
}

QPushButton#pushButton_2_send:pressed {
    background-color: #115e59;
}</string>
